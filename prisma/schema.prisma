generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model MaxUser {
  id              String   @id @default(cuid())
  maxId           String   @unique
  username        String?
  firstName       String?
  lastName        String?
  hasConsent      Boolean  @default(false)
  createdAt       String?
  updatedAt       String?

  state           MaxUserState?
  waitlistEntries MaxWaitlistEntry[]
  feldsherApplications MaxFeldsherApplication[]
  questions       MaxQuestion[]
}

model MaxUserState {
  id              String   @id @default(cuid())
  maxUserId       String   @unique
  currentStep     String
  flowType        String
  data            String?
  createdAt       String?
  updatedAt       String?

  maxUser         MaxUser @relation(fields: [maxUserId], references: [id], onDelete: Cascade)
}

model MaxWaitlistEntry {
  id              String   @id @default(cuid())
  maxUserId       String
  name            String
  phone           String
  district        String
  createdAt       String?

  maxUser         MaxUser @relation(fields: [maxUserId], references: [id], onDelete: Cascade)
}

model MaxFeldsherApplication {
  id              String   @id @default(cuid())
  maxUserId       String
  name            String
  phone           String
  experience      String
  scheduleType    String
  resumeLink      String?
  createdAt       String?

  maxUser         MaxUser @relation(fields: [maxUserId], references: [id], onDelete: Cascade)
}

model MaxQuestion {
  id              String   @id @default(cuid())
  maxUserId       String
  name            String
  phone           String
  question        String
  isAnswered      Boolean  @default(false)
  createdAt       String?

  maxUser         MaxUser @relation(fields: [maxUserId], references: [id], onDelete: Cascade)
}
