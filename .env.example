# MAX Messenger Bot Environment Variables
# ========================================

# MAX Bot Token (get from @MaxBotFather in MAX)
MAX_BOT_TOKEN=your_bot_token_here

# Admin User ID (for admin commands and notifications fallback)
# You can get your ID by messaging @userinfobot in MAX
MAX_ADMIN_ID=162749713

# Channel/Chat ID for notifications (preferred)
# Format: negative number for channels, e.g. -72328888338961
MAX_CHANNEL_ID=-72328888338961

# Database URL (SQLite for Amvera)
DATABASE_URL=file:/app/data/custom.db

# Port for HTTP server (Amvera sets this automatically)
PORT=8080
